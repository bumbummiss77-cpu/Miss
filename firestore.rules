rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for global safety and authentication
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com'
      );
    }

    // Checking roles securely.
    // Supports matching simulated user roles or direct email bootstraps (lourendzaurbay@gmail.com)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'lourendzaurbay@gmail.com' ||
        request.auth.token.email.matches('.*@missmoçambique\\.co\\.mz') || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isJury() {
      return isSignedIn() && (
        request.auth.token.email.matches('.*@jurado\\.org\\.mz') || 
        exists(/databases/$(database)/documents/juries/$(request.auth.uid))
      );
    }

    // Helper to validate alphanumeric IDs to prevent directory transversal
    function isValidId(id) {
      return id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Global Deny-by-default rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins lookup collection (only readable by signed in, writable only by bootstrapped main admin)
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.email == 'lourendzaurbay@gmail.com';
    }

    // Juries lookup collection (readable by signed in, writeable only by admin)
    match /juries/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 1. CANDIDATES collection
    // - Anyone can read approved candidates.
    // - Signed in users (registered candidate or user) can read their own if pending/rejected.
    // - Create/Inscribe: Candidates can register profiles, starting with "pending" status.
    // - Update: Admins can update any field. Jurors can only trigger scoring mechanics (implied via evaluation hooks, or calculated server-side). Public users can view, view updates increment view count only.
    match /candidates/{candidateId} {
      allow read: if isValidId(candidateId) && (
        resource.data.status == 'approved' || 
        isAdmin() || 
        (isSignedIn() && resource.data.id == request.auth.uid)
      );
      
      allow create: if isSignedIn() && isValidId(candidateId) && (
        isAdmin() || (
          // Inscription rules for public registrations
          request.resource.data.status == 'pending' &&
          request.resource.data.votesCount == 0 &&
          request.resource.data.viewsCount == 0 &&
          request.resource.data.juryScore == 0 &&
          request.resource.data.fullName is string &&
          request.resource.data.fullName.size() > 2 &&
          request.resource.data.fullName.size() < 100 &&
          request.resource.data.stageName is string &&
          request.resource.data.stageName.size() > 1 &&
          request.resource.data.stageName.size() < 50
        )
      );

      allow update: if isValidId(candidateId) && (
        isAdmin() || (
          // Allow Incrementing views count publicly
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewsCount']) &&
          request.resource.data.viewsCount == resource.data.viewsCount + 1
        ) || (
          // Allow Incrementing votes count through direct transaction trigger simulated on client-side
          // (Only allow when voting increments is proportional)
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votesCount']) &&
          request.resource.data.votesCount >= resource.data.votesCount &&
          request.resource.data.votesCount <= resource.data.votesCount + 1000
        ) || (
          // Allow Updating jury rating average on evaluation submissions
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['juryScore']) &&
          request.resource.data.juryScore >= 1.0 &&
          request.resource.data.juryScore <= 10.0
        )
      );

      allow delete: if isAdmin() && isValidId(candidateId);
    }

    // 2. SYSTEM SETTINGS collection
    // - Readable by anyone to populate current voting rules/prices/stages
    // - Only writable/updatable by admin
    match /settings/{settingsId} {
      allow read: if isValidId(settingsId);
      allow write: if isAdmin() && isValidId(settingsId) && (
        request.resource.data.juryVoteWeight + request.resource.data.publicVoteWeight == 100 &&
        request.resource.data.paidVotePriceMZN is int &&
        request.resource.data.paidVotePriceMZN >= 0
      );
    }

    // 3. JURY EVALUATIONS collection
    // - Readable by admins and juries. Approved/public rankings calculated.
    // - Create: Only juries (or admins) can create evaluations for an existing approved candidate.
    // - Update & Delete: Strictly prohibited to ensure grading immutability (except by Admins under override).
    match /evaluations/{evaluationId} {
      allow read: if isValidId(evaluationId) && (isAdmin() || isJury());
      
      allow create: if isValidId(evaluationId) && (isAdmin() || isJury()) && (
        request.resource.data.juryId == request.auth.uid &&
        request.resource.data.communication >= 1 && request.resource.data.communication <= 10 &&
        request.resource.data.presence >= 1 && request.resource.data.presence <= 10 &&
        request.resource.data.confidence >= 1 && request.resource.data.confidence <= 10 &&
        request.resource.data.runway >= 1 && request.resource.data.runway <= 10 &&
        request.resource.data.talent >= 1 && request.resource.data.talent <= 10 &&
        // Referencing check: verify target candidate document exists
        exists(/databases/$(database)/documents/candidates/$(request.resource.data.candidateId))
      );

      allow update, delete: if isAdmin() && isValidId(evaluationId);
    }

    // 4. VOTE TRANSACTIONS collection
    // - Immutable Ledger keeping track of paid/unpaid votes.
    // - Readable by admins, or individuals checking their own logged email transactions.
    // - Create: Signed-in users can log transactions.
    // - Update / Delete: STRLCTLY Forbidden. Immutable ledger.
    match /transactions/{transactionId} {
      allow read: if isValidId(transactionId) && (
        isAdmin() || 
        (isSignedIn() && resource.data.voterEmail == request.auth.token.email)
      );
      
      allow create: if isValidId(transactionId) && (
        request.resource.data.votesQuantity >= 1 &&
        request.resource.data.votesQuantity <= 1000 &&
        (request.resource.data.paymentMethod in ['mpesa', 'emola', 'mkesh', 'visa']) &&
        exists(/databases/$(database)/documents/candidates/$(request.resource.data.candidateId))
      );

      allow update, delete: if false; // Strict immutable transaction logic
    }

    // 5. AUDIT LOGS collection
    // - Write-only secure audit logs for actions taken.
    // - Read: Only admins can query audit logs.
    // - Create: Signed-in users can log operations they take.
    // - Update / Delete: Strictly Forbidden.
    match /auditLogs/{logId} {
      allow read: if isAdmin() && isValidId(logId);
      allow create: if isSignedIn() && isValidId(logId) && (
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.action is string &&
        request.resource.data.ipAddress is string
      );
      allow update, delete: if false; // Strict audit immutability
    }
  }
}
